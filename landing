.gv-oath{margin-top:34px;font-family:var(--disp);font-size:1.28rem;line-height:1.9;color:var(--paper)!important}
.gv-oath em{font-style:normal;color:var(--brass)}
.gv-id-card{border:1px solid var(--brass-soft);border-radius:6px;background:linear-gradient(160deg,var(--ink-3),var(--ink));padding:30px 28px;position:relative;box-shadow:0 30px 80px rgba(0,0,0,.45);transform:rotate(-1.2deg)}
.gv-id-card::after{content:"å·¨";position:absolute;right:18px;bottom:8px;font-family:var(--disp);font-size:4.6rem;font-weight:800;color:transparent;-webkit-text-stroke:1px rgba(201,162,75,.28)}
.gv-id-head{font-family:var(--mono);font-size:.64rem;letter-spacing:.26em;text-transform:uppercase;color:var(--brass);margin-bottom:18px;display:flex;justify-content:space-between}
.gv-id-row{display:flex;justify-content:space-between;gap:16px;padding:11px 0;border-bottom:1px dashed var(--line)}
.gv-id-row:last-of-type{border-bottom:none}
.gv-id-k{font-family:var(--mono);font-size:.64rem;letter-spacing:.2em;text-transform:uppercase;color:var(--paper-dim)}
.gv-id-v{font-family:var(--disp);font-size:.98rem;color:var(--paper);text-align:right}
.gv-id-v.gold{color:var(--brass);font-weight:700}

.gv-fin{padding:140px 24px;text-align:center}
.gv-fin h2{margin:0 auto;max-width:22ch;font-size:clamp(1.9rem,4.4vw,3.2rem)}
.gv-fin p:not(.gv-eyebrow){margin:22px auto 0;color:var(--paper-dim);max-width:46ch}

.gv-footer{border-top:1px solid var(--line);padding:34px 24px;display:flex;justify-content:space-between;gap:20px;flex-wrap:wrap;font-family:var(--mono);font-size:.68rem;letter-spacing:.14em;color:var(--paper-dim)}

.gv-reveal{opacity:0;transform:translateY(26px);transition:opacity .7s,transform .7s}
.gv-reveal.in{opacity:1;transform:none}

@media (prefers-reduced-motion:reduce){
  .gv-root *{animation:none!important;transition:none!important}
  .gv-reveal{opacity:1;transform:none}
}
@media (max-width:880px){
  .gv-callings{grid-template-columns:1fr}
  .gv-vow-grid{grid-template-columns:1fr;gap:48px}
  .gv-realm-strip{flex-direction:column;min-height:0}
  .gv-realm{border-left:none;border-top:1px solid var(--line);padding:24px 20px}
  .gv-realm:first-child{border-top:none}
  .gv-r-order{writing-mode:horizontal-tb;position:static;margin-bottom:10px}
  .gv-realm.open{flex:1}
  .gv-r-desc{max-height:none;opacity:1}
  .gv-step{grid-template-columns:64px 1fr;gap:18px;padding:28px 0}
  .gv-kanji{right:-14vw;opacity:.7}
  .gv-root section{padding:84px 0}
}
`;